{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local"],
  "globalPassThroughEnv": [
    "PATH",
    "HOME",
    "USER",
    "LANG",
    "LC_ALL",
    "ANDROID_HOME",
    "ANDROID_SDK_ROOT",
    "ANDROID_NDK_HOME",
    "JAVA_HOME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_BASE_URL",
        "GOOGLE_API_KEY",
        "GEMINI_MODEL",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT",
        "ALLOWED_ORIGINS",
        "VITE_API_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "biome.jsonc", "ruff.toml"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.rs", "src/**/*.ts", "src/**/*.tsx"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interactive": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_BASE_URL",
        "CLOUDFLARE_ACCOUNT_ID",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT",
        "GOOGLE_API_KEY",
        "GEMINI_MODEL",
        "VITE_API_BASE_URL",
        "VITE_AUTH_BASE_URL",
        "ALLOWED_ORIGINS",
        "RUST_LOG",
        "API_PORT",
        "NEXT_PUBLIC_API_BASE_URL",
        "EXPO_PUBLIC_API_URL",
        "EXPO_PUBLIC_APP_ENV"
      ]
    }
  }
}
