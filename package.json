{
  "name": "expent",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo build",
    "clean": "cargo clean && pnpm -r --if-present clean && rm -rf .turbo .venv .pytest_cache .ruff_cache",
    "dev": "dotenv -- turbo dev",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "lint": "biome lint --write --no-errors-on-unmatched",
    "fmt": "biome format --write",
    "typecheck": "dotenv -- turbo typecheck",
    "test": "dotenv -- turbo test",
    "test:core": "cargo test -p expent_core",
    "test:dashboard": "pnpm --filter @expent/dashboard test",
    "test:ocr": "cd apps/ocr && uv run pytest",
    "test:all": "pnpm test:core && pnpm test:dashboard && pnpm test:ocr",
    "fmt-all": "cargo fmt && uv format && pnpm fmt",
    "bacon:dev": "bacon dev",
    "bacon:lint": "bacon clippy-all",
    "bacon:check": "bacon check-all",
    "bacon:test": "bacon nextest",
    "app": "pnpm --filter @expent/app",
    "app:dev": "pnpm --filter @expent/app dev",
    "app:ios": "pnpm --filter @expent/app ios",
    "app:android": "pnpm --filter @expent/app android",
    "app:emulator": "pnpm --filter @expent/app emulator",
    "db:seed": "uv run --with requests python scripts/seed.py",
    "skills:install": "pnpm dlx skills experimental_install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.3",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  }
}
